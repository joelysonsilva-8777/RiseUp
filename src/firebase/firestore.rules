rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, create, update, delete: if isOwner(userId);
    }

    match /users/{userId}/{document=**} {
      allow read, create, update, delete: if isOwner(userId);
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.sellerId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.productId == productId
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5
          && exists(/databases/$(database)/documents/productPurchases/$(request.auth.uid + "_" + productId));
        allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }
    }

    match /productPurchases/{purchaseId} {
      allow read: if isSignedIn() && purchaseId.matches(request.auth.uid + "_.*");
      allow create, update: if isSignedIn()
        && purchaseId.matches(request.auth.uid + "_.*")
        && request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /profiles/{userId} {
      allow read, create, update, delete: if isOwner(userId);
    }

    match /sellerProfiles/{sellerId} {
      allow read: if true;
      allow create, update, delete: if isOwner(sellerId);

      match /followers/{followerId} {
        allow read: if true;
        allow create, delete: if isOwner(followerId);
        allow update: if false;
      }

      match /messages/{messageId} {
        allow create: if isSignedIn()
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.sellerId == sellerId;
        allow read: if isSignedIn()
          && (request.auth.uid == sellerId || resource.data.senderId == request.auth.uid);
        allow update, delete: if false;
      }
    }

    match /messageThreads/{threadId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participantIds
        && request.resource.data.participantIds == resource.data.participantIds;
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participantIds
        && request.resource.data.participantIds.size() == 2;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/messageThreads/$(threadId)).data.participantIds;
        allow create: if isSignedIn()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/messageThreads/$(threadId)).data.participantIds;
        allow update, delete: if false;
      }
    }

    match /public/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
